rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // No public access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Family data — only the owning user can read/write.
    // familyId == the authenticated user's UID.
    match /families/{familyId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == familyId;
    }

    // Chapter book library — global, shared across families.
    // Readable and writable by any authenticated user. Single-family app today;
    // scope writes to admins if multi-family support is ever added.
    match /chapterBooks/{bookId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Shelly Chat threads + messages (explicit for subcollection clarity)
    function isFamily(familyId) {
      return request.auth != null && request.auth.uid == familyId;
    }
    match /families/{familyId}/shellyChatThreads/{threadId} {
      allow read, write: if isFamily(familyId);
      match /messages/{messageId} {
        allow read, write: if isFamily(familyId);
      }
    }
  }
}
