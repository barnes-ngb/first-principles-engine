rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Shared size + type constraints
    function isValidUpload() {
      return request.resource.size < 25 * 1024 * 1024
          && request.resource.contentType.matches('image/.*|audio/.*|video/.*');
    }

    function isOwner(familyId) {
      return request.auth != null && request.auth.uid == familyId;
    }

    // Artifacts (existing — photos, audio, notes from Today/Dad Lab)
    match /families/{familyId}/artifacts/{allPaths=**} {
      allow read: if isOwner(familyId);
      allow write: if isOwner(familyId) && isValidUpload();
    }

    // Books (photos, audio narration, uploaded images)
    match /families/{familyId}/books/{allPaths=**} {
      allow read: if isOwner(familyId);
      allow write: if isOwner(familyId) && isValidUpload();
    }

    // Sticker library (AI-generated stickers)
    match /families/{familyId}/stickers/{allPaths=**} {
      allow read: if isOwner(familyId);
      allow write: if isOwner(familyId) && isValidUpload();
    }

    // Story Game Workshop (voice recordings + generated art)
    match /families/{familyId}/storyGames/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isOwner(familyId) && isValidUpload();
    }

    // Chat uploads (user-uploaded images for AI analysis/transform)
    match /families/{familyId}/chat-uploads/{allPaths=**} {
      allow read: if isOwner(familyId);
      allow write: if isOwner(familyId) && isValidUpload();
    }

    // Generated images (AI-created via Cloud Functions — written server-side, read client-side)
    match /families/{familyId}/generated-images/{allPaths=**} {
      allow read: if isOwner(familyId);
      // Write is server-side only (admin SDK) — no client write rule needed
    }
  }
}
