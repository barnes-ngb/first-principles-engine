rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Shared size + type constraints
    function isValidUpload() {
      return request.resource.size < 25 * 1024 * 1024
          && request.resource.contentType.matches('image/.*|audio/.*|video/.*');
    }

    function isOwner(familyId) {
      return request.auth != null && request.auth.uid == familyId;
    }

    // Artifacts (existing — photos, audio, notes from Today/Dad Lab)
    match /families/{familyId}/artifacts/{allPaths=**} {
      allow read: if isOwner(familyId);
      allow write: if isOwner(familyId) && isValidUpload();
    }

    // Books (photos, audio narration, uploaded images)
    match /families/{familyId}/books/{allPaths=**} {
      allow read: if isOwner(familyId);
      allow write: if isOwner(familyId) && isValidUpload();
    }

    // Sticker library (AI-generated stickers)
    match /families/{familyId}/stickers/{allPaths=**} {
      allow read: if isOwner(familyId);
      allow write: if isOwner(familyId) && isValidUpload();
    }

    // Story Game Workshop (voice recordings + generated art)
    match /families/{familyId}/storyGames/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isOwner(familyId) && isValidUpload();
    }

    // Chat uploads (user-uploaded images for AI analysis/transform)
    match /families/{familyId}/chat-uploads/{allPaths=**} {
      allow read: if isOwner(familyId);
      allow write: if isOwner(familyId) && isValidUpload();
    }

    // Scans (workbook page and certificate photos)
    match /families/{familyId}/scans/{allPaths=**} {
      allow read: if isOwner(familyId);
      allow write: if isOwner(familyId) && isValidUpload();
    }

    // Sketches (hand-drawn sketches uploaded for book pages + portfolio)
    match /families/{familyId}/sketches/{allPaths=**} {
      allow read: if isOwner(familyId);
      allow write: if isOwner(familyId) && isValidUpload();
    }

    // Chapter responses (audio recordings of kids answering read-aloud questions)
    match /families/{familyId}/chapterResponses/{allPaths=**} {
      allow read: if isOwner(familyId);
      allow write: if isOwner(familyId) && isValidUpload();
    }

    // Generated images (AI-created via Cloud Functions — written server-side, read client-side)
    match /families/{familyId}/generated-images/{allPaths=**} {
      allow read: if isOwner(familyId);
      // Write is server-side only (admin SDK) — no client write rule needed
    }

    // Public catalog storefront (FEAT-84 — the ONLY world-readable path tree).
    //
    // A parent taps "Publish site" in the Barnes Bros → Catalog section, which
    // uploads a self-contained static lookbook (public/catalog/{familyId}/index.html)
    // of that family's `status:'listed'` products. Read is PUBLIC so a family opens
    // the shared URL on a phone with no login; this is the deliberate,
    // owner-approved exposure of that path tree — nothing else here is world-readable.
    //
    // The page is **scoped per family** — write (create/update = republish, delete
    // = unpublish) is gated on `isOwner(familyId)`, so one family can never
    // overwrite or take down another's storefront, matching the per-`families/`
    // scoping used everywhere else. The app further gates the controls on `canEdit`
    // (parent-only). Uploads are size-capped and restricted to the HTML page + any
    // referenced images. No `families/{familyId}/**` data and no Firestore read is
    // opened by this rule — the page is a baked static snapshot.
    match /public/catalog/{familyId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isOwner(familyId)
          && request.resource.size < 5 * 1024 * 1024
          && request.resource.contentType.matches('text/html.*|image/.*');
      allow delete: if isOwner(familyId);
    }
  }
}
